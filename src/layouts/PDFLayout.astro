---
const { title = "CV Empresa", lang = "es" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>

    <style>
      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: #ffffff;
        color: #0f172a;
        font-family: "Inter", "Segoe UI", Arial, sans-serif;
        font-size: 10.6pt;
        line-height: 1.45;
      }

      @page {
        size: A4;
        margin: 18mm;
      }

      .pdf-page {
        width: 100%;
      }

      /* ===== HEADER ===== */

      .header {
        display: grid;
        grid-template-columns: 2.5fr 1fr;
        gap: 14px;
        align-items: start;
      }

      h1 {
        font-size: 18pt;
        margin: 0;
        font-weight: 800;
        letter-spacing: -0.02em;
      }

      .role {
        font-size: 11pt;
        font-weight: 600;
        color: #1e293b;
        margin-top: 2px;
      }

      .meta {
        font-size: 9.5pt;
        color: #475569;
        margin-top: 2px;
      }

      .header-right {
        text-align: right;
      }

      .badge {
        display: inline-block;
        border: 1px solid #cbd5e1;
        padding: 3px 8px;
        border-radius: 5px;
        font-size: 9pt;
        margin-bottom: 6px;
      }

      .divider {
        height: 1px;
        background: #0f172a;
        margin: 12px 0 14px 0;
      }

      /* ===== SECTIONS ===== */

      h2 {
        font-size: 11pt;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin: 12px 0 6px 0;
        border-bottom: 1px solid #cbd5e1;
        padding-bottom: 4px;
      }

      .section {
        margin-top: 6px;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr 1.6fr;
        gap: 20px;
        margin-top: 8px;
      }

      .col {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .block {
        margin-bottom: 6px;
      }

      ul {
        margin: 4px 0 4px 14px;
        padding: 0;
      }

      li {
        margin: 2px 0;
      }

      /* ===== JOB ===== */

      .job {
        margin-top: 4px;
      }

      .job-head {
        display: flex;
        justify-content: space-between;
        font-size: 10pt;
        font-weight: 600;
      }

      .company {
        color: #020617;
      }

      .date {
        color: #64748b;
      }

      .job-role {
        font-size: 9.8pt;
        font-weight: 600;
        margin: 2px 0 4px 0;
        color: #1e293b;
      }

      /* ===== NOTES ===== */

      .note {
        font-size: 9.4pt;
        color: #64748b;
        font-style: italic;
        margin-top: 2px;
      }

      .no-break {
        page-break-inside: avoid;
      }

    </style>
  </head>

  <body>
    <div class="pdf-page">
      <slot />
    </div>
  </body>
</html>
