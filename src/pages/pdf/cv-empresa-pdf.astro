---
import PDFEmpresaLayout from "../../layouts/PDFEmpresaLayout.astro";
---

<PDFEmpresaLayout title="CV Empresa | Miguel Del Pino Muelas" lang="es">

  <section class="header no-break">
    <div>
      <h1>Miguel Del Pino Muelas</h1>
      <div class="role">Desarrollador de aplicaciones multiplataforma</div>
      <div class="meta">
        Talavera de la Reina, España · migueldelpinoms@gmail.com
      </div>
    </div>

    <div class="header-right">
      <div class="tag">Disponibilidad inmediata</div>
      <div class="tag">Perfil híbrido</div>
    </div>
  </section>

  <div class="divider"></div>

  <section class="no-break">
    <h2>Perfil profesional</h2>
    <p>
      Desarrollador de aplicaciones multiplataforma con enfoque en construcción de productos digitales reales
      y soluciones tecnológicas orientadas a negocio. Experiencia en desarrollo web moderno, aplicaciones móviles
      y arquitectura de software, combinada con trayectoria profesional en gestión, liderazgo operativo y
      optimización de procesos.
    </p>
    <p>
      Perfil híbrido técnico–empresarial, orientado a entornos profesionales donde aportar valor técnico,
      estructural y organizativo y participar en proyectos de impacto real.
    </p>
  </section>

  <section class="two-col">

    <div>
      <div class="block no-break">
        <h2>Tecnologías</h2>
        <ul class="clean-list">
          <li><strong>Frontend:</strong> HTML5, CSS3, JavaScript (ES6+), Astro</li>
          <li><strong>Backend:</strong> Node.js, APIs REST</li>
          <li><strong>Arquitectura:</strong> Modular, separación de capas</li>
          <li><strong>Herramientas:</strong> Git, GitHub, Postman</li>
        </ul>
      </div>

      <div class="block no-break">
        <h2>Formación</h2>
        <p><strong>CFGS Desarrollo de Aplicaciones Multiplataforma (DAM)</strong></p>
      </div>

      <div class="block no-break">
        <h2>Idiomas</h2>
        <p>Español nativo · Inglés técnico · Alemán intermedio</p>
      </div>
    </div>

    <div>
      <div class="block">
        <h2>Experiencia profesional</h2>

        <div class="job no-break">
          <div class="job-header">
            <span>Renault</span>
            <span>2017 – 2024 · España</span>
          </div>

          <div class="job-role">
            Responsable de departamento — Vehículos de ocasión
          </div>

          <ul>
            <li>Gestión integral del departamento</li>
            <li>Optimización de procesos operativos</li>
            <li>Liderazgo de equipos</li>
          </ul>
        </div>
      </div>

      <div class="block no-break">
        <h2>Proyecto destacado</h2>

        <div class="job">
          <div class="job-header">
            <span>Discover Castilla-La Mancha</span>
            <span>Aplicación Android</span>
          </div>

          <p>
            Desarrollo completo de aplicación turística: arquitectura, frontend, backend
            e integración de servicios.
          </p>

          <p class="small muted">
            Kotlin · Firebase · MVVM · JUnit
          </p>
        </div>
      </div>
    </div>

  </section>

</PDFEmpresaLayout>
