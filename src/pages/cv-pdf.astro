---
import PDFLayout from "../layouts/PDFLayout.astro";
---

<PDFLayout title="CV Empresa | Miguel Del Pino" lang="es">

  <!-- HEADER -->
  <section class="header no-break">
    <div class="header-left">
      <h1>Miguel Del Pino Muelas</h1>
      <div class="role">Desarrollador de aplicaciones multiplataforma</div>
      <div class="meta">
        Talavera de la Reina, España · migueldelpinoms@gmail.com
      </div>
    </div>

    <div class="header-right">
      <span class="badge">Disponibilidad inmediata</span>
      <span class="badge">Perfil híbrido</span>
    </div>
  </section>

  <div class="divider"></div>

  <!-- PERFIL -->
  <section class="section">
    <h2>Perfil profesional</h2>
    <p>
      Desarrollador de aplicaciones con enfoque en construcción de productos digitales reales.
      Especializado en desarrollo web moderno, aplicaciones móviles y arquitectura de software.
      Orientado a entornos profesionales donde aportar valor técnico, crecer profesionalmente
      y participar en proyectos de impacto real.
    </p>
  </section>

  <!-- GRID -->
  <section class="grid">

    <!-- LEFT COLUMN -->
    <div class="col">

      <div class="block">
        <h2>Tecnologías</h2>
        <ul class="list">
          <li><strong>Frontend:</strong> HTML, CSS, JavaScript, Astro, Tailwind</li>
          <li><strong>Backend:</strong> Node.js, APIs REST</li>
          <li><strong>Arquitectura:</strong> Componentes, estructuración modular</li>
          <li><strong>Otros:</strong> Git, SEO técnico, accesibilidad, testing</li>
        </ul>
      </div>

      <div class="block">
        <h2>Formación</h2>
        <p><strong>CFGS Desarrollo de Aplicaciones Multiplataforma (DAM)</strong></p>
      </div>

      <div class="block">
        <h2>Idiomas</h2>
        <p>Español nativo · Inglés técnico · Alemán intermedio</p>
      </div>

    </div>

    <!-- RIGHT COLUMN -->
    <div class="col">

      <div class="block">
        <h2>Experiencia profesional</h2>

        <div class="job">
          <div class="job-head">
            <span class="company">Renault</span>
            <span class="date">2017 – 2024 · España</span>
          </div>

          <div class="job-role">
            Responsable de departamento — Vehículos de ocasión
          </div>

          <ul>
            <li>Gestión integral del departamento de vehículos de ocasión</li>
            <li>Coordinación de procesos comerciales, operativos y administrativos</li>
            <li>Optimización de procesos internos orientados a eficiencia operativa</li>
            <li>Liderazgo, organización y gestión de equipos</li>
          </ul>
        </div>
      </div>

      <div class="block">
        <h2>Proyectos</h2>
        <p>
          Desarrollo continuo de proyectos personales orientados a mejora técnica,
          aprendizaje de nuevas tecnologías y construcción de productos digitales reales.
        </p>
        <p class="note">
          Preparado para integración futura con portfolio profesional.
        </p>
      </div>

    </div>

  </section>

</PDFLayout>
