---
import PDFEmpresaLayout from "../layouts/PDFEmpresaLayout.astro";
---

<PDFEmpresaLayout title="CV Empresa | Miguel Del Pino Muelas" lang="es">

  <section class="header no-break">
    <div>
      <h1>Miguel Del Pino Muelas</h1>
      <div class="role">Desarrollador de aplicaciones multiplataforma</div>
      <div class="meta">
        Talavera de la Reina, España · migueldelpinoms@gmail.com
      </div>
    </div>

    <div class="header-right">
      <div class="tag">Disponibilidad inmediata</div>
      <div class="tag">Perfil híbrido</div>
    </div>
  </section>

  <div class="divider"></div>

  <section class="no-break">
    <h2>Perfil profesional</h2>
    <p>
      Desarrollador de aplicaciones multiplataforma con enfoque en construcción de productos digitales reales y
      soluciones tecnológicas orientadas a negocio. Experiencia en desarrollo web moderno, aplicaciones móviles
      y arquitectura de software, combinada con trayectoria profesional en gestión, liderazgo operativo y
      optimización de procesos.
    </p>
    <p>
      Perfil híbrido técnico–empresarial, orientado a entornos profesionales donde aportar valor técnico,
      estructural y organizativo, participar en proyectos de impacto real y crecer dentro de equipos tecnológicos sólidos.
    </p>
  </section>

  <section class="two-col">

    <!-- IZQUIERDA -->
    <div>

      <div class="block no-break">
        <h2>Tecnologías</h2>
        <ul class="clean-list">
          <li><strong>Frontend:</strong> HTML5, CSS3, JavaScript (ES6+), Astro, Tailwind CSS</li>
          <li><strong>Backend:</strong> Node.js, APIs REST, JSON</li>
          <li><strong>Arquitectura:</strong> Arquitectura modular, componentes, separación de capas</li>
          <li><strong>Herramientas:</strong> Git, GitHub, Postman, testing básico, SEO técnico, accesibilidad web</li>
        </ul>
      </div>

      <div class="block no-break">
        <h2>Formación</h2>
        <p><strong>CFGS Desarrollo de Aplicaciones Multiplataforma (DAM)</strong></p>
      </div>

      <div class="block no-break">
        <h2>Idiomas</h2>
        <p>Español nativo · Inglés técnico · Alemán intermedio</p>
      </div>

    </div>

    <!-- DERECHA -->
    <div>

      <div class="block">
        <h2>Experiencia profesional</h2>

        <div class="job no-break">
          <div class="job-header">
            <span>Renault</span>
            <span>2017 – 2024 · España</span>
          </div>

          <div class="job-role">
            Responsable de departamento — Vehículos de ocasión
          </div>

          <ul>
            <li>Gestión integral del departamento y operaciones</li>
            <li>Coordinación de procesos comerciales, operativos y administrativos</li>
            <li>Optimización de procesos internos orientados a eficiencia operativa</li>
            <li>Liderazgo y gestión de equipos multidisciplinares</li>
            <li>Organización de flujos de trabajo y control de calidad de procesos</li>
            <li>Toma de decisiones operativas en entornos de alta responsabilidad</li>
          </ul>
        </div>

      </div>

      <!-- PLATAFORMA PROFESIONAL -->
      <div class="block no-break">
        <h2>Plataforma profesional (producto digital propio)</h2>

        <p>
          Desarrollo de plataforma web profesional como infraestructura técnica personal.
          Arquitectura modular, estructuración semántica, SEO técnico, accesibilidad, rendimiento,
          internacionalización y diseño orientado a producto.
        </p>

        <p class="small muted">
          Base de presentación profesional, proyectos, documentación técnica y expansión de productos digitales.
        </p>
      </div>

      <!-- PROYECTOS DESTACADOS -->
      <div class="block no-break">
        <h2>Proyectos destacados</h2>

        <div class="job no-break">
          <div class="job-header">
            <span>Discover Castilla-La Mancha</span>
            <span>Aplicación Android</span>
          </div>

          <p>
            Desarrollo completo de aplicación orientada a promoción cultural y turística.
            Diseño de arquitectura, desarrollo frontend y backend, integración de servicios
            y experiencia de usuario.
          </p>

          <p class="small muted">
            Tecnologías: Kotlin, Android Studio, Firebase Authentication, Firebase Realtime Database,
            MVVM, JUnit, Espresso.
          </p>
        </div>

      </div>

    </div>

  </section>

</PDFEmpresaLayout>
