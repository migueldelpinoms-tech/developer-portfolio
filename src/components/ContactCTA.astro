---
const { t } = Astro.props;

/* Translations */
const copyAlert = t("contact.copy_alert");
const mailSubject = t("contact.mail_subject");
---

<section
  id="contact"
  class="relative py-28 md:py-36
         bg-gradient-to-b from-gray-50 to-white
         dark:from-gray-950 dark:to-black
         text-black dark:text-white
         overflow-hidden"
  data-copy-alert={copyAlert}
  data-mail-subject={mailSubject}
>

  <!-- Fondo decorativo -->
  <div class="absolute inset-0 pointer-events-none z-0">
    <div
      class="absolute -top-32 left-1/2 -translate-x-1/2
             w-[500px] h-[500px]
             bg-black/5 dark:bg-white/5
             rounded-full blur-3xl">
    </div>
  </div>

  <!-- Contenido -->
  <div
    class="relative z-10 max-w-[900px] mx-auto px-6 text-center"
    data-aos="fade-up"
  >

    <!-- Título -->
    <h2 class="text-3xl md:text-4xl font-extrabold mb-6 tracking-tight">
      {t("contact.title")}
    </h2>

    <!-- Texto -->
    <p
      class="text-lg text-gray-700 dark:text-gray-300
             mb-12 max-w-[720px] mx-auto
             leading-relaxed"
    >
      {t("contact.description")}
    </p>

    <!-- Botones -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center">

      <!-- Email -->
      <button
        id="btn-mail-final"
        type="button"
        class="inline-flex items-center justify-center
               px-10 py-4 rounded-2xl
               bg-black dark:bg-white
               text-white dark:text-black
               font-semibold text-lg
               transition-all duration-300
               hover:scale-[1.05]
               hover:shadow-[0_20px_40px_rgba(0,0,0,0.25)]
               active:scale-[0.97]"
      >
        {t("contact.button")}
      </button>

      <!-- Copy -->
      <button
        id="btn-copy-final"
        type="button"
        class="inline-flex items-center justify-center
               px-10 py-4 rounded-2xl
               border border-black dark:border-white
               text-black dark:text-white
               font-semibold text-lg
               transition-all duration-300
               hover:bg-black hover:text-white
               dark:hover:bg-white dark:hover:text-black"
      >
        {t("contact.copy_btn")}
      </button>

    </div>

    <!-- Email -->
    <p class="mt-6 text-sm text-gray-500 dark:text-gray-400">
      migueldelpinoms@gmail.com
    </p>

    <!-- Microcopy -->
    <p class="mt-2 text-xs text-gray-400">
      {t("contact.microcopy")}
    </p>

  </div>

  <script is:inline>

    document.addEventListener("DOMContentLoaded", () => {

      const section = document.getElementById("contact");

      const COPY_ALERT = section.dataset.copyAlert;
      const MAIL_SUBJECT = section.dataset.mailSubject;

      const btnMail = document.getElementById("btn-mail-final");
      const btnCopy = document.getElementById("btn-copy-final");

      if (btnMail) {
        btnMail.addEventListener("click", () => {

          const subject = encodeURIComponent(MAIL_SUBJECT);

          window.location.href =
            `mailto:migueldelpinoms@gmail.com?subject=${subject}`;

        });
      }

      if (btnCopy) {
        btnCopy.addEventListener("click", () => {

          navigator.clipboard.writeText("migueldelpinoms@gmail.com");

          alert(COPY_ALERT);

        });
      }

    });

  </script>

</section>
