---
const { t } = Astro.props;

const skills = t("skills") || {};
---

<section
  id="skills"
  class="py-24 md:py-32
         bg-white dark:bg-[#020817]
         text-black dark:text-white"
  data-aos="fade-up"
  data-aos-duration="800"
>

  <div class="max-w-[1100px] mx-auto px-6 text-center">

    <!-- TITLE -->
    <h2 class="text-3xl md:text-4xl font-bold mb-6">
      {skills.title}
    </h2>

    <!-- DESCRIPTION -->
    <p
      class="text-gray-600 dark:text-gray-400
             max-w-2xl mx-auto mb-16
             text-lg leading-relaxed"
    >
      {skills.description}
    </p>

    <!-- CARDS -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-left">

      <!-- FRONTEND -->
      <div class="skill-card">
        <h3 class="text-xl font-semibold mb-6">
          {skills.frontend?.title}
        </h3>

        <ul class="space-y-3 text-gray-700 dark:text-gray-300">
          {skills.frontend?.items?.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <!-- MOBILE -->
      <div class="skill-card">
        <h3 class="text-xl font-semibold mb-6">
          {skills.mobile?.title}
        </h3>

        <ul class="space-y-3 text-gray-700 dark:text-gray-300">
          {skills.mobile?.items?.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <!-- TOOLS -->
      <div class="skill-card">
        <h3 class="text-xl font-semibold mb-6">
          {skills.tools?.title}
        </h3>

        <ul class="space-y-3 text-gray-700 dark:text-gray-300">
          {skills.tools?.items?.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

    </div>

  </div>

</section>

<style>

.skill-card {
  border-radius: 1rem;
  padding: 2rem;

  background: linear-gradient(145deg, #f8fafc, #e5e7eb);

  box-shadow: 0 6px 18px rgba(0,0,0,.12);
  transition: all .3s ease;
}

/* DARK MODE */
html.dark .skill-card {
  background: linear-gradient(145deg, #0f172a, #111827);
  box-shadow: 0 8px 25px rgba(0,0,0,.35);
}

.skill-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 15px 40px rgba(0,0,0,.25);
}

html.dark .skill-card:hover {
  box-shadow: 0 18px 45px rgba(0,0,0,.45);
}

</style>
