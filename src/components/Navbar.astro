---
import ThemeToggle from "./ThemeToggle.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  lang?: string;
  t?: (key: string) => string;
}

const { lang, t } = Astro.props as Props;

const fallbackMap: Record<string, string> = {
  "navbar.home": "Inicio",
  "navbar.projects": "Proyectos",
  "navbar.skills": "Habilidades",
  "navbar.contact": "Contacto"
};

function translate(key: string): string {
  if (typeof t === "function") {
    const value = t(key);
    if (value && value !== key) return value;
  }
  return fallbackMap[key] ?? key;
}
---

<nav
  id="main-navbar"
  class="navbar fixed top-0 left-0 w-full z-50"
  role="navigation"
  aria-label="Navegación principal"
>
  <div
    class="navbar-inner max-w-[1120px] mx-auto px-6 h-16
           flex items-center justify-between"
  >

    <!-- LOGO -->
    <a
      href={`/${lang ?? ""}`}
      class="logo-link font-bold text-base md:text-lg tracking-tight"
    >
      Michael.dev
    </a>

    <!-- LINKS DESKTOP -->
    <div class="nav-links hidden md:flex items-center gap-10">

      <a href={`/${lang ?? ""}#home`} class="nav-link">
        {translate("navbar.home")}
      </a>

      <a href={`/${lang ?? ""}#projects`} class="nav-link">
        {translate("navbar.projects")}
      </a>

      <a href={`/${lang ?? ""}#skills`} class="nav-link">
        {translate("navbar.skills")}
      </a>

      <a href={`/${lang ?? ""}#about`} class="nav-link">
        {translate("navbar.contact")}
      </a>

    </div>

    <!-- ACTIONS -->
    <div class="flex items-center gap-3">

      <!-- CV (MISMO DISEÑO QUE LOS OTROS) -->
      <a href="/cv" class="pill-btn">
        <span class="cv-icon">📄</span>
        CV
      </a>

      <LanguageSwitcher lang={lang ?? "es"} />
      <ThemeToggle t={t} />

      <!-- MOBILE -->
      <button
        id="mobile-toggle"
        class="md:hidden mobile-btn"
        aria-label="Abrir menú"
      >
        ☰
      </button>

    </div>

  </div>

  <!-- MOBILE MENU -->
  <div id="mobile-menu" class="mobile-menu md:hidden">

    <a href={`/${lang ?? ""}#home`} class="mobile-link">
      {translate("navbar.home")}
    </a>

    <a href={`/${lang ?? ""}#projects`} class="mobile-link">
      {translate("navbar.projects")}
    </a>

    <a href={`/${lang ?? ""}#skills`} class="mobile-link">
      {translate("navbar.skills")}
    </a>

    <a href={`/${lang ?? ""}#about`} class="mobile-link">
      {translate("navbar.contact")}
    </a>

  </div>
</nav>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {

  const navbar = document.getElementById("main-navbar");
  const mobileBtn = document.getElementById("mobile-toggle");
  const mobileMenu = document.getElementById("mobile-menu");

  /* ENTRANCE */

  navbar?.classList.add("navbar-enter");

  setTimeout(() => {
    navbar?.classList.add("navbar-enter-active");
  }, 50);


  /* MOBILE */

  if (mobileBtn && mobileMenu) {
    mobileBtn.addEventListener("click", () => {
      mobileMenu.classList.toggle("open");
    });
  }


  /* SCROLL */

  function handleScroll() {

    if (window.scrollY > 20) {
      document.body.classList.add("navbar-scrolled");
    } else {
      document.body.classList.remove("navbar-scrolled");
    }

  }

  handleScroll();
  window.addEventListener("scroll", handleScroll, { passive: true });


  /* ACTIVE LINK */

  const links = document.querySelectorAll(".nav-link");
  const sections = ["home","projects","skills","about"];

  function updateActive() {

    let current = "";

    sections.forEach(id => {

      const el = document.getElementById(id);
      if (!el) return;

      const top = el.offsetTop - 120;

      if (window.scrollY >= top) current = id;

    });

    links.forEach(link => {

      link.classList.remove("active");

      if (link.getAttribute("href")?.includes(`#${current}`)) {
        link.classList.add("active");
      }

    });

  }

  updateActive();
  window.addEventListener("scroll", updateActive, { passive: true });

});
</script>

<style>

/* ===============================
   NAVBAR BASE
=============================== */

.navbar {
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10px);

  border-bottom: 1px solid rgb(229 231 235);

  transition:
    background .25s ease,
    box-shadow .25s ease,
    transform .5s ease,
    opacity .5s ease;
}

/* DARK */
html.dark .navbar {
  background: rgba(2,8,23,0.95);
  border-color: rgb(31 41 55);
}


/* SCROLL */

body.navbar-scrolled .navbar {
  background: rgba(255,255,255,0.98);
  box-shadow: 0 8px 25px rgba(0,0,0,.15);
}

html.dark body.navbar-scrolled .navbar {
  background: rgba(2,8,23,0.98);
  box-shadow: 0 8px 25px rgba(0,0,0,.45);
}


/* ===============================
   ENTRANCE
=============================== */

.navbar-enter {
  opacity: 0;
  transform: translateY(-20px);
}

.navbar-enter-active {
  opacity: 1;
  transform: translateY(0);
}


/* ===============================
   LOGO
=============================== */

.logo-link {
  color: rgb(17 24 39);
}

html.dark .logo-link {
  color: white;
}


/* ===============================
   LINKS
=============================== */

.nav-link {
  position: relative;

  font-size: .875rem;
  font-weight: 500;

  color: rgb(55 65 81);
  transition: all .2s ease;
}

html.dark .nav-link {
  color: white;
}

.nav-link:hover {
  transform: translateY(-1px);
}

.nav-link.active {
  font-weight: 600;
}

.nav-link::after {
  content: "";

  position: absolute;
  left: 0;
  bottom: -6px;

  width: 100%;
  height: 2px;

  background: currentColor;

  transform: scaleX(0);
  transition: transform .25s ease;
}

.nav-link.active::after,
.nav-link:hover::after {
  transform: scaleX(1);
}


/* ===============================
   PILL BUTTON (CV + TOGGLES)
=============================== */

.pill-btn {
  display: inline-flex;
  align-items: center;
  gap: .35rem;

  padding: .45rem .9rem;

  font-size: .75rem;
  font-weight: 600;

  border-radius: 9999px;
  border: 1px solid rgb(209 213 219);

  background: transparent;
  color: rgb(17 24 39);

  transition: all .25s ease;
}

html.dark .pill-btn {
  border-color: rgb(55 65 81);
  color: white;
}

.pill-btn:hover {
  background: rgb(243 244 246);
  transform: translateY(-1px);
}

html.dark .pill-btn:hover {
  background: rgb(31 41 55);
}


/* ===============================
   MOBILE
=============================== */

.mobile-btn {
  font-size: 1.4rem;
}

.mobile-menu {
  max-height: 0;
  overflow: hidden;

  background: inherit;

  transition: max-height .35s ease;
}

.mobile-menu.open {
  max-height: 300px;
}

.mobile-link {
  display: block;

  padding: 1rem 1.5rem;

  font-weight: 500;

  border-top: 1px solid rgba(255,255,255,.1);

  transition: background .2s ease;
}

.mobile-link:hover {
  background: rgba(255,255,255,.05);
}

</style>
